{
  "scripts": {
    "test": "jest",
    "test:unit": "mocha UT/**/*.unit.test.js --reporter spec --timeout 5000",
    "test:sql-injection": "mocha UT/sql-injection.unit.test.js --reporter spec --timeout 5000",
    "test:functions": "mocha UT/functions.unit.test.js --reporter spec --timeout 5000",
    "test:coverage": "nyc mocha UT/**/*.unit.test.js --reporter spec --timeout 5000",
    "test:performance": "jest UT/*.performance.test.js",
    "test:performance:watch": "jest UT/*.performance.test.js --watch",
    "test:register": "jest UT/register.performance.test.js",
    "test:authenticate": "jest UT/authenticate.performance.test.js",
    "test:concurrency": "jest UT/concurrency.performance.test.js",
    "test:report": "node UT/performance-report.js",
    "test:all": "npm run test:unit && npm run test:performance"
  },
  "dependencies": {
    "@hexagon/base64": "^1.1.25",
    "@peculiar/webcrypto": "^1.4.1",
    "axios": "^1.3.4",
    "base64url": "^3.0.1",
    "cbor-x": "^1.5.1",
    "comment-json": "^4.2.3",
    "dayjs": "^1.11.7",
    "dotenv": "^16.0.3",
    "jose": "^4.11.2",
    "jsrsasign": "^11.1.0",
    "log4js": "^6.7.1",
    "mysql2": "^3.16.0",
    "pkijs": "^3.0.13",
    "str2ab": "^1.2.1",
    "tldts": "^5.7.104",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mocha": "^11.7.5",
    "nyc": "^15.1.0",
    "sinon": "^17.0.1",
    "supertest": "^6.3.3"
  }
}
