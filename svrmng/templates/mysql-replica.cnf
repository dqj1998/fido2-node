# =============================================================================
# MySQL 从服务器配置
# =============================================================================
# 复制到 /etc/mysql/conf.d/replica.cnf
# =============================================================================

[mysqld]
# 服务器ID（从服务器使用2及以上）
server-id = 2

# 中继日志
relay_log = mysql-relay-bin
relay_log_purge = ON

# 只读模式（从服务器）
read_only = ON

# 启用二进制日志（如果需要级联复制）
log_bin = mysql-bin
binlog_format = ROW

# 字符集
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# 连接设置
max_connections = 200
wait_timeout = 600
interactive_timeout = 600

# 缓冲区设置（从服务器可以小一些）
innodb_buffer_pool_size = 512M
innodb_log_file_size = 128M

# 允许远程连接
bind-address = 0.0.0.0

# 复制过滤（如果需要只复制特定数据库）
# replicate-do-db = fido2_node_db
# replicate-do-db = fido2_portal_db

# 跳过复制错误（谨慎使用）
# slave_skip_errors = 1062
