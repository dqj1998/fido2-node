# =============================================================================
# fido2-portal 环境变量模板
# =============================================================================
# 占位符由部署脚本替换
# =============================================================================

# Environment
NODE_ENV=production

# Server Configuration
PORT={{PORT}}
PORTAL_DOMAIN=portal.{{DOMAIN}}

# Session Configuration
SESSION_SECRET={{SESSION_SECRET}}
SESSION_TIMEOUT_MINUTES={{SESSION_TIMEOUT}}
SESSION_COOKIE_NAME=fido2_portal_session
SESSION_COOKIE_PATH=/
SESSION_COOKIE_SECURE=true

# MySQL Database Configuration
MYSQL_HOST={{MYSQL_HOST}}
MYSQL_DATABASE={{MYSQL_DATABASE}}
MYSQL_USER={{MYSQL_USER}}
MYSQL_PASSWORD={{MYSQL_PASSWORD}}
MYSQL_POOL_LIMIT=10
MYSQL_CONNECTION_TIMEOUT=10000

# FIDO2 Server Configuration
MNG_API_TOKEN={{MNG_API_TOKEN}}
FIDO2_SERVER_URL=https://fido2.{{DOMAIN}}
FIDO2_WORKER_URLS={{WORKER_URLS}}

# SMTP Configuration (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Registration Links
# REGISTRATION_LINK_PREFIX=https://portal.{{DOMAIN}}/register
# INVITATION_LINK_PREFIX=https://portal.{{DOMAIN}}/invite
# REGISTRATION_LINK_TIMEOUT=15
# INVITATION_LINK_TIMEOUT=15
