{
  "apps": [
    {
      "name": "fido2-node",
      "script": "main.js",
      "cwd": "/opt/fido2-node",
      "instances": "max",
      "exec_mode": "cluster",
      "watch": false,
      "max_memory_restart": "500M",
      "env": {
        "NODE_ENV": "production"
      },
      "error_file": "/opt/fido2-node/logs/pm2-error.log",
      "out_file": "/opt/fido2-node/logs/pm2-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true,
      "min_uptime": "10s",
      "max_restarts": 10,
      "restart_delay": 4000,
      "autorestart": true,
      "kill_timeout": 5000,
      "listen_timeout": 8000
    }
  ]
}
