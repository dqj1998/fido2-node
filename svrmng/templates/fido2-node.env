# =============================================================================
# fido2-node 环境变量模板
# =============================================================================
# 占位符由部署脚本替换:
#   {{PORT}}, {{STORAGE}}, {{MYSQL_HOST}}, {{MYSQL_DATABASE}}
#   {{MYSQL_USER}}, {{MYSQL_PASSWORD}}, {{DOMAIN}}, {{MNG_API_TOKEN}}
# =============================================================================

# Server Configuration
PORT={{PORT}}

# Storage Type: mysql or mem
STORAGE={{STORAGE}}

# MySQL Database Configuration
MYSQL_HOST={{MYSQL_HOST}}
MYSQL_DATABASE={{MYSQL_DATABASE}}
MYSQL_USER={{MYSQL_USER}}
MYSQL_PASSWORD={{MYSQL_PASSWORD}}
MYSQL_POOL_LIMIT=10
MYSQL_CONNECTION_TIMEOUT=10000

# FIDO2 Configuration
FIDO_ORIGIN=https://fido2.{{DOMAIN}}
FIDO_RPID=fido2.{{DOMAIN}}

# Management API
MNG_API_TOKEN={{MNG_API_TOKEN}}

# Extension Module
ENABLE_EX={{ENABLE_EX}}

# Conformance Testing (disable in production)
# CONFORMANCE_TEST=true
